{
  "ignorePatterns": [
    ".venv/**",
    "node_modules/**",
    "build/**",
    "dist/**",
    ".git/**",
    "docs/ZUBAN_FIX_SUMMARY.md",
    "docs/archive/**",         # Ignore archived docs with broken relative links
    "docs/CLAUDE_QWEN_CONFIG_SYNC.md",  # Contains placeholder URLs for migration docs
    ".claude/commands/**",
    "coverage_report/**",
    "htmlcov/**",
    "*.egg-info/**"
  ],
  "retryCount": 3,
  "timeout": "5s"
}
